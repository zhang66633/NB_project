# ============================================
# MathModelAgent 环境变量配置
# 复制此文件为 .env 并填入你的真实 Key
# ============================================

# ---- LLM API Keys ----
# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API Key（可选，使用 GPT 模型时需要）
OPENAI_API_KEY=sk-xxx

# Anthropic API Key（可选，使用 Claude 模型时需要）
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Model Selection (每个 Agent 使用的模型) ----
CLASSIFIER_MODEL=deepseek-chat
PLANNER_MODEL=deepseek-chat
ANALYSIS_MODEL=deepseek-chat
MODELING_MODEL=deepseek-chat
SOLVING_MODEL=deepseek-chat
VERIFICATION_MODEL=deepseek-chat
WRITING_MODEL=deepseek-chat

# ---- Model Parameters ----
DEFAULT_TEMPERATURE=0.0
DEFAULT_MAX_TOKENS=8192

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- ChromaDB ----
CHROMA_PERSIST_DIR=./data/chroma_db

# ---- Knowledge Base ----
KB_ROOT_DIR=./knowledge_base

# ---- Sandbox ----
SANDBOX_TIMEOUT=60
SANDBOX_MAX_MEMORY_MB=512

# ---- Server ----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ---- GitHub OAuth ----
# 在 https://github.com/settings/developers 创建 OAuth App
# Homepage URL: http://localhost:5173
# Authorization callback URL: http://localhost:8000/api/auth/callback
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx
GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback

# ---- JWT ----
# 随机字符串，用于签名登录 Token
JWT_SECRET=change-me-to-a-random-string
